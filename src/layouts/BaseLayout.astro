---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'SOC Operations Portal — incident response playbooks, tooling registry, and CIS controls tracking.' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navLinks = [
  { href: `${base}/playbooks`, label: 'Playbooks' },
  { href: `${base}/registry`, label: 'Registry' },
  { href: `${base}/controls`, label: 'CIS Controls' },
  { href: `${base}/escalation`, label: 'Escalation' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-sandbox-bg text-sandbox-text">
    <header class="sticky top-0 z-10 border-b border-slate-800 bg-slate-950/90 backdrop-blur print:hidden">
      <nav class="max-w-6xl mx-auto px-4 py-3 flex items-center gap-8">
        <a href={base || '/'} class="font-mono font-bold text-lg text-emerald-400 hover:text-emerald-300 transition-colors shrink-0">
          &#x1F6E1; SOC Portal
        </a>
        <div class="flex items-center gap-1 flex-wrap">
          {navLinks.map(link => {
            const isActive = currentPath.startsWith(link.href);
            return (
              <a
                href={link.href}
                class={`px-3 py-1.5 text-sm font-mono transition-colors ${
                  isActive
                    ? 'text-white bg-slate-700 rounded'
                    : 'text-slate-400 hover:text-white hover:bg-slate-800 rounded'
                }`}
              >
                {link.label}
              </a>
            );
          })}
        </div>
      </nav>
    </header>

    <slot />

    <footer class="border-t border-slate-800 mt-16 print:hidden">
      <div class="max-w-6xl mx-auto px-4 py-6 flex justify-between items-center text-xs text-slate-500 font-mono">
        <span>SOC Operations Portal &mdash; SecOps Team</span>
        <span>Static &bull; Offline-capable &bull; GitHub Pages</span>
      </div>
    </footer>
  </body>
</html>

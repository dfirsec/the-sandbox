---
import { getCollection, render } from 'astro:content';
// Ensure this path matches your layout location
import Layout from '../../layouts/BaseLayout.astro';

// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map(post => ({
    params: { slug: post.id }, // This line fixes your error!
    props: { post },
  }));
}

// 2. Get the post directly from the props
const { post } = Astro.props;

// 3. Render the Markdown content to HTML
const { Content } = await render(post);
---

<Layout title={post.data.title}>
  <article class="max-w-3xl mx-auto px-6 py-12">
    <h1 class="text-4xl font-bold font-mono text-sandbox-accent mb-4">
      {post.data.title}
    </h1>
    <p class="text-slate-400 mb-8">{post.data.description}</p>

    <!-- The prose class is for Tailwind Typography, making Markdown look great -->
    <div class="prose prose-invert prose-emerald max-w-none">
      <Content />
    </div>
  </article>
</Layout>
---
import { getCollection } from 'astro:content';
// Ensure this matches your actual layout name!
import Layout from '../../layouts/BaseLayout.astro';

// Fetch all the markdown files from the blog collection
const posts = await getCollection('blog');
---

<Layout title="Blog | The Sandbox">
  <main class="max-w-4xl mx-auto px-6 py-12">
    <div class="mb-12 border-b border-slate-800 pb-4">
      <h1 class="text-4xl font-black font-mono text-sandbox-accent uppercase tracking-tighter">
        Lab Reports <span class="animate-pulse">_</span>
      </h1>
      <p class="text-slate-400 mt-2">Index of security research and development logs.</p>
    </div>

    <div class="grid gap-6">
      {posts.map((post) => (
        <article class="p-6 border border-slate-800 hover:border-sandbox-accent transition-colors bg-slate-900/50">
          <!-- CRITICAL FIX: Use BASE_URL and post.id -->
          <a href={`${import.meta.env.BASE_URL}/blog/${post.id}`} class="block group">
            <h2 class="text-2xl font-bold text-white mb-2 group-hover:text-sandbox-accent transition-colors">
              {post.data.title}
            </h2>
            <p class="text-slate-400 mb-4">
              {post.data.description}
            </p>
            <div class="flex items-center text-sm font-mono text-sandbox-accent uppercase tracking-widest">
              Read Report
              <span class="ml-2 group-hover:translate-x-1 transition-transform">-></span>
            </div>
          </a>
        </article>
      ))}
    </div>
  </main>
</Layout>
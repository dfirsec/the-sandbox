---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="py-16 text-center">
    <h1 class="text-5xl font-extrabold tracking-tight mb-4">
      🧪 <span class="text-indigo-600 dark:text-indigo-400">the-sandbox</span>
    </h1>
    <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto mb-8">
      A developer playground to experiment with Astro, React Islands, Content Collections, and Tailwind CSS.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href={`${base}/blog`}
        class="px-6 py-2.5 rounded-lg bg-indigo-600 text-white font-semibold hover:bg-indigo-700 transition-colors"
      >
        Read the Blog
      </a>
      <a
        href={`${base}/portfolio`}
        class="px-6 py-2.5 rounded-lg border border-gray-300 dark:border-gray-700 font-semibold hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors"
      >
        View Portfolio
      </a>
    </div>
  </section>

  <!-- Feature Callouts -->
  <section class="grid grid-cols-1 sm:grid-cols-3 gap-6 py-8 border-t border-gray-100 dark:border-gray-800">
    {[
      { icon: '📝', title: 'Blog', body: 'MDX-powered posts via Astro Content Collections.' },
      { icon: '🗂️', title: 'Portfolio', body: 'Showcase projects using JSON content collections.' },
      { icon: '⚡', title: 'React Islands', body: 'Interactive UI with partial hydration — only what you need.' },
    ].map(({ icon, title, body }) => (
      <div class="rounded-xl border border-gray-200 dark:border-gray-800 p-6 hover:shadow-md transition-shadow">
        <div class="text-3xl mb-3">{icon}</div>
        <h2 class="text-lg font-bold mb-1">{title}</h2>
        <p class="text-sm text-gray-600 dark:text-gray-400">{body}</p>
      </div>
    ))}
  </section>

  <!-- Recent Posts -->
  {posts.length > 0 && (
    <section class="py-10">
      <h2 class="text-2xl font-bold mb-6">Recent Posts</h2>
      <ul class="space-y-4">
        {posts.map((post) => (
          <li class="rounded-xl border border-gray-200 dark:border-gray-800 p-5 hover:shadow-md transition-shadow">
            <a href={`${base}/blog/${post.slug}`} class="group">
              <h3 class="font-semibold text-lg group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
                {post.data.title}
              </h3>
              <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">{post.data.description}</p>
              <time class="text-xs text-gray-400 dark:text-gray-500 mt-2 block">
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>

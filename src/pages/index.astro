---
import Layout from '../layouts/Layout.astro';
---

<Layout title="The Sandbox">
  <main class="max-w-4xl mx-auto px-6 py-20">
    <div class="border-l-4 border-sandbox-accent pl-6 py-4 bg-sandbox-accent/5 rounded-r-lg">
      <h1 class="text-6xl font-black uppercase tracking-tighter">
        The Sandbox <span class="animate-pulse text-sandbox-accent">_</span>
      </h1>
      <p class="mt-2 text-xl text-slate-400 font-mono italic">
        // Digital Forensics & Incident Response Laboratory
      </p>
    </div>

    <section class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="p-6 border border-sandbox-border hover:border-sandbox-accent transition-colors group">
        <h2 class="text-2xl font-bold mb-2 group-hover:text-sandbox-accent">Research Blog</h2>
        <p class="text-slate-400 mb-4">Deep dives into forensic artifacts and malware analysis.</p>
        <a href={`${import.meta.env.BASE_URL}/blog`} class="text-sm font-mono uppercase tracking-widest text-sandbox-accent">Access Terminal -></a>
      </div>

      <div class="p-6 border border-sandbox-border hover:border-sandbox-accent transition-colors group">
        <h2 class="text-2xl font-bold mb-2 group-hover:text-sandbox-accent">Project Lab</h2>
        <p class="text-slate-400 mb-4">A collection of automation tools and security scripts.</p>
        <a href={`${import.meta.env.BASE_URL}/portfolio`} class="text-sm font-mono uppercase tracking-widest text-sandbox-accent">View Reports -></a>
      </div>
    </section>
  </main>
</Layout>
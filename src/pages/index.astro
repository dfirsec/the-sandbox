---
import Layout from "../layouts/BaseLayout.astro";
---

<Layout title="SOC Portal Hub">
  <main class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="text-4xl font-mono font-bold text-white mb-4">
      Security Operations Hub
    </h1>
    <p class="text-slate-400 mb-12">
      Offline-capable static repository for incident response, architecture, and
      compliance.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <a
        href={`${import.meta.env.BASE_URL}/playbooks`}
        class="block p-6 border border-slate-700 bg-slate-900 hover:border-blue-500"
      >
        <h2 class="text-xl font-bold text-white mb-2">IR Playbooks</h2>
        <p class="text-sm text-slate-400">
          Incident response runbooks and containment procedures.
        </p>
      </a>

      <a
        href={`${import.meta.env.BASE_URL}/registry`}
        class="block p-6 border border-slate-700 bg-slate-900 hover:border-blue-500"
      >
        <h2 class="text-xl font-bold text-white mb-2">Tooling Registry</h2>
        <p class="text-sm text-slate-400">
          Active security vendor tracking and deployment status.
        </p>
      </a>

      <a
        href={`${import.meta.env.BASE_URL}/controls`}
        class="block p-6 border border-slate-700 bg-slate-900 hover:border-blue-500"
      >
        <h2 class="text-xl font-bold text-white mb-2">CIS Controls</h2>
        <p class="text-sm text-slate-400">
          Implementation tracking and auditor evidence links.
        </p>
      </a>
    </div>
  </main>
</Layout>

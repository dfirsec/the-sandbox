---
import Layout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sections = [
  {
    href: `${base}/playbooks`,
    title: "IR Playbooks",
    description: "Incident response runbooks and containment procedures for 14 threat scenarios.",
    icon: "🚨",
  },
  {
    href: `${base}/registry`,
    title: "Tooling Registry",
    description: "Security vendor inventory with ownership, deployment status, and contract notes.",
    icon: "🛠️",
  },
  {
    href: `${base}/controls`,
    title: "CIS Controls",
    description: "CIS CSC v8 implementation tracking across all 18 control groups.",
    icon: "✅",
  },
  {
    href: `${base}/escalation`,
    title: "Escalation Directory",
    description: "On-call contacts, vendor support lines, and external agency reporting paths.",
    icon: "📞",
  },
];
---

<Layout title="SOC Operations Portal">
  <main class="max-w-4xl mx-auto px-6 py-16">
    <p class="text-emerald-400 font-mono text-sm mb-3 uppercase tracking-widest">Security Operations Center</p>
    <h1 class="text-4xl font-mono font-bold text-white mb-4">
      SOC Operations Portal
    </h1>
    <p class="text-slate-400 mb-12 max-w-xl">
      Static security portal with no internal infrastructure dependencies. Remains accessible during internal outages as long as internet connectivity is available.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {sections.map(s => (
        <a
          href={s.href}
          class="block p-6 border border-slate-700 bg-slate-900 hover:border-emerald-500 hover:bg-slate-800 transition-colors group"
        >
          <div class="text-2xl mb-3">{s.icon}</div>
          <h2 class="text-xl font-bold text-white mb-2 group-hover:text-emerald-400 transition-colors">{s.title}</h2>
          <p class="text-sm text-slate-400">{s.description}</p>
        </a>
      ))}
    </div>
  </main>
</Layout>

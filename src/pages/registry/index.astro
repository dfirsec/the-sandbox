---
import { getCollection } from "astro:content";
import Layout from "../../layouts/BaseLayout.astro";

const tools = await getCollection("registry");
---

<Layout title="Tooling Registry | SOC Portal">
    <main class="max-w-5xl mx-auto px-6 py-12 text-slate-300">
        <h1
            class="text-3xl font-bold text-white border-b border-slate-700 pb-4 mb-8"
        >
            Security Architecture & Tooling
        </h1>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr
                        class="bg-slate-800 text-slate-200 text-sm uppercase tracking-wider"
                    >
                        <th class="p-4 border-b border-slate-700">Tool Name</th>
                        <th class="p-4 border-b border-slate-700">Category</th>
                        <th class="p-4 border-b border-slate-700">Status</th>
                        <th class="p-4 border-b border-slate-700">Owner</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    {
                        tools.map((tool) => (
                            <tr class="hover:bg-slate-800/50 border-b border-slate-800">
                                <td class="p-4 font-medium text-white">
                                    {tool.data.toolName}
                                </td>
                                <td class="p-4">{tool.data.category}</td>
                                <td class="p-4">
                                    <span
                                        class={
                                            tool.data.status === "Active"
                                                ? "text-green-400"
                                                : "text-yellow-400"
                                        }
                                    >
                                        {tool.data.status}
                                    </span>
                                </td>
                                <td class="p-4">{tool.data.internalOwner}</td>
                            </tr>
                        ))
                    }
                </tbody>
            </table>
        </div>
    </main>
</Layout>

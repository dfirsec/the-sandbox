---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('portfolio');
---

<BaseLayout title="Portfolio" description="Projects from the-sandbox developer playground.">
  <h1 class="text-4xl font-extrabold mb-8">Portfolio</h1>
  <p class="text-gray-600 dark:text-gray-300 mb-10 text-lg">
    A curated showcase of projects and experiments.
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {projects.map((project) => (
      <div class="rounded-xl border border-gray-200 dark:border-gray-800 p-6 flex flex-col gap-3 hover:shadow-md transition-shadow">
        <h2 class="text-lg font-bold">{project.data.title}</h2>
        <p class="text-sm text-gray-600 dark:text-gray-400 flex-1">{project.data.description}</p>

        {project.data.tags && (
          <div class="flex flex-wrap gap-2">
            {project.data.tags.map((tag: string) => (
              <span class="text-xs bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 rounded px-2 py-0.5">
                {tag}
              </span>
            ))}
          </div>
        )}

        <div class="flex gap-3 mt-2">
          {project.data.url && (
            <a
              href={project.data.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:underline"
            >
              Live Demo ↗
            </a>
          )}
          {project.data.repo && (
            <a
              href={project.data.repo}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium text-gray-600 dark:text-gray-400 hover:underline"
            >
              GitHub ↗
            </a>
          )}
        </div>
      </div>
    ))}
  </div>
</BaseLayout>

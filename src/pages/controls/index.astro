---
import { getCollection } from "astro:content";
import Layout from "../../layouts/BaseLayout.astro";

const controls = (await getCollection("controls")).sort((a, b) =>
    a.data.controlId.localeCompare(b.data.controlId, undefined, {
        numeric: true,
        sensitivity: "base",
    }),
);

const statusConfig: Record<string, { icon: string; label: string; classes: string }> = {
    "Implemented":  { icon: "✅", label: "Implemented",  classes: "bg-green-900/60 text-green-300 border border-green-800" },
    "Partial":      { icon: "🔶", label: "Partial",      classes: "bg-yellow-900/60 text-yellow-300 border border-yellow-800" },
    "Not Started":  { icon: "❌", label: "Not Started",  classes: "bg-red-900/60 text-red-300 border border-red-800" },
    "N/A":          { icon: "➖", label: "N/A",          classes: "bg-slate-800 text-slate-400 border border-slate-700" },
};

const totals = controls.reduce<Record<string, number>>((acc, c) => {
    acc[c.data.implementationStatus] = (acc[c.data.implementationStatus] || 0) + 1;
    return acc;
}, {});
---

<Layout title="CIS Controls | SOC Portal">
    <main class="max-w-6xl mx-auto px-6 py-12 text-slate-300">
        <h1 class="text-3xl font-bold text-white border-b border-slate-700 pb-4 mb-6">
            CIS Controls Implementation
        </h1>

        <!-- Summary bar -->
        <div class="flex flex-wrap gap-3 mb-8">
            {Object.entries(statusConfig).map(([status, cfg]) => (
                <div class={`flex items-center gap-2 px-3 py-1.5 rounded text-sm font-mono ${cfg.classes}`}>
                    <span>{cfg.icon}</span>
                    <span>{totals[status] || 0} {cfg.label}</span>
                </div>
            ))}
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-800 text-slate-200 text-sm uppercase tracking-wider">
                        <th class="p-4 border-b border-slate-700 w-24">ID</th>
                        <th class="p-4 border-b border-slate-700 w-1/3">Title</th>
                        <th class="p-4 border-b border-slate-700 w-40">Status</th>
                        <th class="p-4 border-b border-slate-700">Notes</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    {controls.map((ctrl) => {
                        const cfg = statusConfig[ctrl.data.implementationStatus] ?? statusConfig["N/A"];
                        return (
                            <tr class="hover:bg-slate-800/50 border-b border-slate-800">
                                <td class="p-4 font-mono text-blue-400">
                                    {ctrl.data.controlId}
                                </td>
                                <td class="p-4 font-medium text-white">
                                    {ctrl.data.title}
                                </td>
                                <td class="p-4">
                                    <span class={`inline-flex items-center gap-1.5 px-2 py-1 rounded text-xs font-bold ${cfg.classes}`}>
                                        <span>{cfg.icon}</span>
                                        <span>{cfg.label}</span>
                                    </span>
                                </td>
                                <td class="p-4 text-slate-400">
                                    {ctrl.data.notes}
                                </td>
                            </tr>
                        );
                    })}
                </tbody>
            </table>
        </div>
    </main>
</Layout>

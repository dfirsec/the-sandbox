---
import Layout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="404 — Not Found | SOC Portal">
    <main class="max-w-4xl mx-auto px-6 py-24 text-center">
        <p class="text-emerald-400 font-mono text-sm mb-4">HTTP 404</p>
        <h1 class="text-5xl font-bold text-white mb-6">Page Not Found</h1>
        <p class="text-slate-400 mb-10 max-w-md mx-auto">
            The resource you requested does not exist on this portal. It may have been moved or the URL is incorrect.
        </p>
        <div class="flex justify-center gap-4 flex-wrap">
            <a href={`${base}/playbooks`} class="px-4 py-2 border border-slate-600 text-slate-300 hover:border-blue-500 hover:text-white font-mono text-sm transition-colors">
                IR Playbooks
            </a>
            <a href={`${base}/registry`} class="px-4 py-2 border border-slate-600 text-slate-300 hover:border-blue-500 hover:text-white font-mono text-sm transition-colors">
                Tooling Registry
            </a>
            <a href={`${base}/controls`} class="px-4 py-2 border border-slate-600 text-slate-300 hover:border-blue-500 hover:text-white font-mono text-sm transition-colors">
                CIS Controls
            </a>
            <a href={`${base}/escalation`} class="px-4 py-2 border border-slate-600 text-slate-300 hover:border-blue-500 hover:text-white font-mono text-sm transition-colors">
                Escalation Directory
            </a>
        </div>
    </main>
</Layout>

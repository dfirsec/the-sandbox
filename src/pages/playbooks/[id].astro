---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
    const playbooks = await getCollection("playbooks");
    return playbooks.map((book) => ({
        params: { id: book.id },
        props: { book },
    }));
}

const { book } = Astro.props;
const { Content } = await render(book);

const severityStyles: Record<string, string> = {
    Critical: "bg-red-900 border border-red-500 text-red-200",
    High: "bg-orange-900 border border-orange-500 text-orange-200",
    Medium: "bg-yellow-900 border border-yellow-500 text-yellow-200",
    Low: "bg-slate-700 border border-slate-500 text-slate-300",
};

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title={`${book.data.title} | SOC Portal`} description={book.data.description}>
    <article class="max-w-4xl mx-auto px-6 py-12">
        <div class="mb-6 print:hidden">
            <a
                href={`${base}/playbooks`}
                class="text-sm text-slate-400 hover:text-white font-mono transition-colors"
            >
                &larr; All Playbooks
            </a>
        </div>

        <div class="mb-8 border-b border-slate-700 pb-6">
            <div class="flex justify-between items-start gap-4 mb-4">
                <h1 class="text-4xl font-bold text-white">{book.data.title}</h1>
                <span
                    class={`px-3 py-1 text-sm font-bold uppercase shrink-0 ${severityStyles[book.data.severity] ?? severityStyles.Low}`}
                >
                    {book.data.severity}
                </span>
            </div>
            <p class="text-lg text-slate-400">{book.data.description}</p>
            <div class="mt-4 flex items-center justify-between">
                <div class="flex gap-6 text-sm text-slate-500 font-mono">
                    <span>Author: {book.data.author}</span>
                    <span>Updated: {book.data.lastUpdated.toISOString().split("T")[0]}</span>
                </div>
                <button
                    id="reset-btn"
                    class="hidden print:hidden text-xs font-mono text-slate-500 hover:text-red-400 border border-slate-700 hover:border-red-800 px-3 py-1 transition-colors"
                >
                    Reset progress
                </button>
            </div>
        </div>

        <div class="prose prose-invert prose-slate max-w-none" id="playbook-content">
            <Content />
        </div>

        <div class="mt-12 pt-6 border-t border-slate-800 print:hidden">
            <a
                href={`${base}/playbooks`}
                class="text-sm text-slate-400 hover:text-white font-mono transition-colors"
            >
                &larr; All Playbooks
            </a>
        </div>
    </article>
</Layout>

<script>
(function () {
    const key = `checklist:${location.pathname}`;
    const state: Record<number, boolean> = JSON.parse(localStorage.getItem(key) || '{}');
    const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement | null;

    function saveState() {
        localStorage.setItem(key, JSON.stringify(state));
    }

    function syncResetBtn() {
        if (!resetBtn) return;
        const anyChecked = Object.values(state).some(Boolean);
        resetBtn.classList.toggle('hidden', !anyChecked);
    }

    function applyChecked(li: HTMLElement, checked: boolean) {
        li.style.opacity = checked ? '0.45' : '1';
        li.style.textDecoration = checked ? 'line-through' : 'none';
        li.style.textDecorationColor = '#475569';
    }

    const prose = document.getElementById('playbook-content');
    if (!prose) return;

    const ols = prose.querySelectorAll<HTMLOListElement>('ol');
    let globalIndex = 0;

    ols.forEach(ol => {
        ol.style.listStyle = 'none';
        ol.style.paddingLeft = '0';

        ol.querySelectorAll<HTMLLIElement>(':scope > li').forEach(li => {
            const index = globalIndex++;
            const checked = !!state[index];

            li.style.display = 'flex';
            li.style.alignItems = 'flex-start';
            li.style.gap = '0.625rem';
            li.style.marginBottom = '0.75rem';

            const cb = document.createElement('input');
            cb.type = 'checkbox';
            cb.checked = checked;
            cb.style.cssText = 'margin-top:0.3rem;width:1rem;height:1rem;flex-shrink:0;accent-color:#10b981;cursor:pointer';
            cb.setAttribute('aria-label', `Mark step ${index + 1} complete`);

            cb.addEventListener('change', () => {
                state[index] = cb.checked;
                applyChecked(li, cb.checked);
                saveState();
                syncResetBtn();
            });

            li.prepend(cb);
            applyChecked(li, checked);
        });
    });

    syncResetBtn();

    resetBtn?.addEventListener('click', () => {
        prose.querySelectorAll<HTMLInputElement>('ol > li > input[type="checkbox"]').forEach((cb, i) => {
            cb.checked = false;
            state[i] = false;
            applyChecked(cb.closest('li') as HTMLElement, false);
        });
        saveState();
        syncResetBtn();
    });
})();
</script>
